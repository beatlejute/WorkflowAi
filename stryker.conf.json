{
  "testRunner": "node",
  "testCommand": "node --test src/tests/scripts-pick-next-task-human-ready.test.mjs",
  "files": [
    "src/scripts/pick-next-task.js"
  ],
  "mutate": [
    "src/scripts/pick-next-task.js"
  ],
  "reporters": [
    "html",
    "clear-text",
    "json"
  ],
  "reportDir": "stryker-report",
