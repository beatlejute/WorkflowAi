{
  "name": "workflow-ai",
  "version": "1.3.1",
  "description": "AI Agent Workflow Coordinator — kanban-based pipeline for AI coding agents",
  "type": "module",
  "bin": {
    "workflow": "./bin/workflow.mjs"
  },
  "files": [
    "bin/",
    "src/cli.mjs",
    "src/init.mjs",
    "src/runner.mjs",
    "src/wf-loader.mjs",
    "src/global-dir.mjs",
    "src/junction-manager.mjs",
    "src/lib/",
    "src/scripts/*.js",
    "src/skills/*/SKILL.md",
    "src/skills/*/index.mjs",
    "templates/",
    "configs/",
    "agent-templates/",
    "CHANGELOG.md"
  ],
  "exports": {
    "./lib/find-root.mjs": "./src/lib/find-root.mjs",
    "./lib/utils.mjs": "./src/lib/utils.mjs",
    "./lib/logger.mjs": "./src/lib/logger.mjs",
    "./lib/js-yaml.mjs": "./src/lib/js-yaml.mjs",
    "./lib/operations/tickets.mjs": "./src/lib/operations/tickets.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test src/tests/*.test.mjs",
    "test:skills": "node src/scripts/run-skill-tests.js --all",
    "coverage": "c8 node --test src/tests/*.test.mjs",
    "coverage:mark-blocked": "c8 node --test src/tests/scripts-mark-blocked.test.mjs",
    "coverage:pick-next-task": "node scripts/coverage-pick-next-task.js",
    "coverage:move-ticket": "c8 node --test src/tests/scripts-move-ticket-approval-hook.test.mjs",
    "mutation-test": "stryker run",
    "release": "npm version patch && npm publish"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/javascript-mutator": "^4.0.0",
    "c8": "^11.0.0"
  }
}
